# ══════════════════════════════════════════════════════════════════════════════
# Strapi v3 → v5 Migration Middleware — Environment Configuration
# Copy this file to .env and fill in your values.
# ══════════════════════════════════════════════════════════════════════════════

# ─── Strapi v3 ────────────────────────────────────────────────────────────────
# Base URL of your Strapi v3 instance (no trailing slash)
STRAPI_V3_URL=http://localhost:1337

# Full-access API token from Strapi v3 Admin → Settings → API Tokens
STRAPI_V3_TOKEN=your-strapi-v3-api-token-here

# ─── Strapi v5 ────────────────────────────────────────────────────────────────
# Base URL of your Strapi v5 instance (no trailing slash)
STRAPI_V5_URL=http://localhost:1338

# Full-access API token from Strapi v5 Admin → Settings → API Tokens
STRAPI_V5_TOKEN=your-strapi-v5-api-token-here

# ─── AWS S3 ───────────────────────────────────────────────────────────────────
# Both v3 and v5 use the same S3 bucket.
# The migration downloads files from S3 via their public/pre-signed URLs
# and re-uploads them to the v5 media library.
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-s3-bucket-name

# ─── Rate limiting ────────────────────────────────────────────────────────────
# Number of entries to fetch per API call (max 100 recommended)
BATCH_SIZE=100

# Milliseconds to wait between every API call (30000 = 30 seconds)
DELAY_MS=30000

# Maximum retry attempts for a single HTTP request before giving up
MAX_RETRIES=5

# ─── i18n / Localization ─────────────────────────────────────────────────────
# Comma-separated list of locales your Strapi instances support.
# The FIRST locale is treated as the default locale.
SUPPORTED_LOCALES=en,fr,de,es

# ─── --all flag master list ───────────────────────────────────────────────────
# Used when you run: node index.js --all
# Comma-separated list of ALL collection slugs to migrate
ALL_COLLECTIONS=articles,authors,categories,products,pages

# Comma-separated list of ALL single type slugs to migrate
ALL_SINGLE_TYPES=homepage,global,about

# ─── Logging ──────────────────────────────────────────────────────────────────
# Path to the log file (relative to the migration/ directory, or absolute)
LOG_FILE=./migration.log

# ─── Advanced field mapping (optional) ───────────────────────────────────────
# Map relation field names to their related collection slug.
# This helps the fieldMapper correctly resolve relation fields.
# Format: JSON object, keyed by content type slug.
# Example: articles has an "author" (single relation to authors)
#          and "tags" (many relation to tags)
RELATION_SLUG_MAP={"articles":{"author":"authors","tags":"tags","category":"categories"},"products":{"brand":"brands"}}

# Explicitly mark which fields are dynamic zones (array of component objects).
# Auto-detection usually works, but this is a safety net.
# Format: JSON object, keyed by content type slug.
DYNAMIC_ZONE_FIELDS={"articles":["content","sections"],"pages":["blocks"]}

# Optional component UID remapping if UIDs changed between v3 and v5.
# Format: JSON object, old UID → new UID.
# Leave empty if UIDs are the same (most common case).
COMPONENT_UID_MAP={}

# Per-field type override hints (advanced).
# Use only if auto-detection of field types is incorrect for a specific content type.
# Format: JSON object, keyed by content type slug → field name → "media" | "relation:slug"
FIELD_TYPE_HINTS={}

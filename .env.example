# ══════════════════════════════════════════════════════════════════════════════
# Strapi v3 → v5 Migration Middleware — Environment Configuration
# Copy this file to .env and fill in your values.
# No API tokens required — both Strapi instances are accessed without auth.
# ══════════════════════════════════════════════════════════════════════════════

# ─── Strapi v3 ────────────────────────────────────────────────────────────────
# Base URL of your Strapi v3 instance (no trailing slash)
STRAPI_V3_URL=http://localhost:1337

# ─── Strapi v5 ────────────────────────────────────────────────────────────────
# Base URL of your Strapi v5 instance (no trailing slash)
STRAPI_V5_URL=http://localhost:1338

# ─── Rate Limiting ────────────────────────────────────────────────────────────
# Number of entries to fetch per API call (max 100 recommended)
BATCH_SIZE=100

# Milliseconds to wait between every API call (30000 = 30 seconds)
DELAY_MS=30000

# Maximum HTTP retry attempts before giving up on a single request
MAX_RETRIES=5

# ─── i18n / Localization ─────────────────────────────────────────────────────
# Comma-separated list of locales your Strapi instances support.
# The FIRST locale is treated as the default locale.
SUPPORTED_LOCALES=en,fr,de,es


# ─── Logging ──────────────────────────────────────────────────────────────────
# Path to the log file (relative to the migration/ directory, or absolute path)
LOG_FILE=./migration.log

# ══════════════════════════════════════════════════════════════════════════════
# No API tokens, AWS credentials, or manual field mapping needed.
#
# Relations, dynamic zones, and component schemas are auto-detected from:
#   GET /content-manager/content-types/:uid  (Strapi v3)
#   GET /content-manager/components/:uid     (Strapi v3)
#
# Media files are downloaded from their v3 URL (S3 or local) and uploaded
# to Strapi v5 which stores them via its own configured upload plugin.
# ══════════════════════════════════════════════════════════════════════════════

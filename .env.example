# ── Required ──────────────────────────────────────────────────────────────────
STRAPI_V3_URL=http://localhost:1337
STRAPI_V5_URL=http://localhost:1338

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Entries fetched per API call
BATCH_SIZE=100

# Milliseconds to wait between API calls (lower = faster, higher = safer)
DELAY_MS=5000

# Max HTTP retries on 5xx errors
MAX_RETRIES=3

# ── i18n ──────────────────────────────────────────────────────────────────────
# Comma-separated. First locale is the default.
SUPPORTED_LOCALES=en

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_FILE=./migration.log

# ══════════════════════════════════════════════════════════════════════════════
# Strapi v3 → v5 Migration Middleware — Environment Configuration
# Copy this file to .env and fill in your values.
# ══════════════════════════════════════════════════════════════════════════════

# ─── Strapi v3 ────────────────────────────────────────────────────────────────
# Base URL of your Strapi v3 instance (no trailing slash)
STRAPI_V3_URL=http://localhost:1337

# Full-access API token from Strapi v3 Admin → Settings → API Tokens
# Must have read access to both the public API and Content Manager API
STRAPI_V3_TOKEN=your-strapi-v3-api-token-here

# ─── Strapi v5 ────────────────────────────────────────────────────────────────
# Base URL of your Strapi v5 instance (no trailing slash)
STRAPI_V5_URL=http://localhost:1338

# Full-access API token from Strapi v5 Admin → Settings → API Tokens
# Must have read + write access to both the public API and Content Manager API
STRAPI_V5_TOKEN=your-strapi-v5-api-token-here

# ─── Rate Limiting ────────────────────────────────────────────────────────────
# Number of entries to fetch per API call (max 100 recommended)
BATCH_SIZE=100

# Milliseconds to wait between every API call (30000 = 30 seconds)
DELAY_MS=30000

# Maximum HTTP retry attempts before giving up on a single request
MAX_RETRIES=5

# ─── i18n / Localization ─────────────────────────────────────────────────────
# Comma-separated list of locales your Strapi instances support.
# The FIRST locale is treated as the default locale.
SUPPORTED_LOCALES=en,fr,de,es

# ─── --all flag master list ───────────────────────────────────────────────────
# Used only when you run: node index.js --all
# Comma-separated list of ALL collection slugs to migrate
ALL_COLLECTIONS=articles,authors,categories,products,pages

# Comma-separated list of ALL single type slugs to migrate
ALL_SINGLE_TYPES=homepage,global,about

# ─── Logging ──────────────────────────────────────────────────────────────────
# Path to the log file (relative to the migration/ directory, or absolute path)
LOG_FILE=./migration.log

# ══════════════════════════════════════════════════════════════════════════════
# NOTE: No manual field mapping configuration is needed.
#
# Relations, dynamic zones, and component field types are detected automatically
# by querying the Strapi v3 Content Manager schema API at runtime:
#   GET /content-manager/content-types/:uid
#   GET /content-manager/components/:uid
#
# Media uploads are handled entirely by Strapi v5 — the middleware passes the
# file URL from v3 and Strapi v5 registers it in its own media library.
# No AWS S3 credentials are required here.
# ══════════════════════════════════════════════════════════════════════════════
